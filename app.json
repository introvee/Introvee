{
  "expo": {
    "name": "Introvee",
    "slug": "introvert-app",
    "scheme": "introvee",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "updates": {
      "enabled": false
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bravestep.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF8F3"
      },
      "package": "com.bravestep.app",
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "20453456-f4e9-498f-b567-74d218b88e3f"
      }
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Introvee can use a photo you choose to personalize your shared progress card.",
          "microphonePermission": false
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Introvee needs photo library access to save your completed dare post.",
          "savePhotosPermission": "Introvee needs permission to save your completed dare post."
        }
      ],
      [
        "react-native-share",
        {
          "ios": [
            "instagram",
            "whatsapp"
          ],
          "android": [
            "com.instagram.android",
            "com.whatsapp"
          ]
        }
      ],
      "expo-localization",
      "expo-build-properties",
      "expo-sharing",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#FAF8F3",
          "imageWidth": 200
        }
      ]
    ]
  }
}
