{
  "expo": {
    "name": "Introve",
    "slug": "introvert-app",
    "scheme": "introvee",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF8F3"
    },
    "updates": {
      "enabled": false
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bravestep.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF8F3"
      },
      "package": "com.bravestep.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "20453456-f4e9-498f-b567-74d218b88e3f"
      }
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Introve can use a photo you choose to personalize your shared progress card.",
          "cameraPermission": "Introve can use your camera to add an optional photo to your shared progress card."
        }
      ]
    ]
  }
}
